{
  "rewrites": [
    { "source": "/api/users/:path*", "destination": "https://macondo.hackclub.com/api/users/:path*" },
    { "source": "/api/projects/:path*", "destination": "https://macondo.hackclub.com/api/projects/:path*" },
    { "source": "/api/slack-proxy/:path*", "destination": "/api/slack-proxy" },
    { "source": "/api/hackclub-ai/:path*", "destination": "/api/hackclub-ai" }
  ],
  "redirects": [
    { "source": "/api/slack-proxy", "destination": "/api/slack-proxy/" },
    { "source": "/api/hackclub-ai", "destination": "/api/hackclub-ai/" }
  ]
}
